# Reverse proxy 全体の設定です。
# 公開ホスト名、listen ポート、各アプリの転送先をここで決めます。

# Docker network 名です。基本はそのままで構いません。
PROXY_NETWORK_NAME=proxy-network

# Traefik がホストで待ち受けるポートです。
HTTP_PORT=80
HTTPS_PORT=443

# Traefik dashboard の内部ポートです。
# 外部には直接公開せず、proxy 経由で使います。
TRAEFIK_INTERNAL_PORT=8088

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# Traefik 本体のイメージとログ設定です。
TRAEFIK_IMAGE=traefik:v2.11
TRAEFIK_LOG_LEVEL=INFO

# 公開ドメインと各サービスのホスト名です。
# 例:
#   DOMAIN=sample.com
#   ROOT_HOST=sample.com
#   TTRSS_HOST=ttrss.sample.com
DOMAIN=example.local
ROOT_HOST=example.local
TTRSS_HOST=ttrss.example.local
MUNIN_HOST=munin.example.local
TATEGAKI_HOST=tategaki.example.local
SYNCTHING_HOST=syncthing.example.local
OPENVPN_HOST=openvpn.example.local
TRAEFIK_HOST=traefik.example.local
EPGREC_HOST=epgrec.example.local
EPGSTATION_HOST=epgstation.example.local
MIRAKURUN_HOST=mirakurun.example.local

# 各サービスの転送先です。
# 通常は localhost の既定ポートのままで大丈夫です。
WORDPRESS_UPSTREAM=127.0.0.1:8080
TTRSS_UPSTREAM=127.0.0.1:8280
MUNIN_UPSTREAM=127.0.0.1:8081
TATEGAKI_UPSTREAM=127.0.0.1:3000
SYNCTHING_UPSTREAM=127.0.0.1:8384
OPENVPN_ADMIN_UPSTREAM=127.0.0.1:943
OPENVPN_CLIENT_UPSTREAM=127.0.0.1:9443
MIRAKURUN_UPSTREAM=127.0.0.1:40772
EPGSTATION_UPSTREAM=127.0.0.1:8888

# Let's Encrypt の通知先メールアドレスです。
LETSENCRYPT_EMAIL=admin@example.local

# 保護された管理画面で使う Basic 認証です。
# munin / mirakurun / epgrec / epgstation / traefik に使います。
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me
